# Runtime secrets — set these on the server or in your local .env file.
# Never commit real values.
TELEGRAM_BOT_TOKEN=
TRACKAI_DESKTOP_UPLOAD_BOT_TOKEN=
TELEGRAM_PROCESSING_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=
DEEPSEEK_API_KEY=

# R3 point-cloud export. Trajectory is returned before this background job.
R3_POINTCLOUD_MAX_POINTS=200000
R3_POINTCLOUD_STRIDE=4
R3_POINTCLOUD_MIN_CONF=1.0
R3_SAVE_FULL_DEBUG=false
# Emergency compatibility switch: true restores the old blocking export.
R3_INLINE_POINTCLOUD=false
# Export the full sparse R3 relative-pose graph for diagnostics and the future
# robust SE(3)/Sim(3) optimizer. The guarded runtime patch is on by default.
R3_EXPORT_POSE_GRAPH_EDGES=true

# Long-video accuracy: keep one native R3 long/streaming run so its keyframe
# bank can re-register revisited places and close loops.
R3_CONTINUOUS_LONG=true
R3_LONG_MIN_DURATION_SECONDS=600
R3_LONG_TARGET_FPS=5
# Match the official R3 release preset: greedy global pose assembly, 100
# novelty keyframes and fallback-segment PGO disabled.
R3_USE_RELEASE_PRESET=true
# Parallax-aware fallback bridges avoid estimating scale from nearly static
# consecutive frames. The release preset pins these production values; they
# remain configurable when R3_USE_RELEASE_PRESET=false.
R3_FALLBACK_MIN_BRIDGE_BASELINE_RATIO=0.35
R3_FALLBACK_MAX_BRIDGE_LOOKBACK=40
# Preserve one relative scale across fallback segments.  Use metric_reanchor
# only for experiments that require DA3 absolute scale; floor-plan rendering
# already has its own map calibration and must not jump scale mid-route.
R3_SCALE_POLICY=bridge_continuity

# Experimental compatibility path only. Independent blocks lose global loop
# closure and should remain disabled for production trajectories.
R3_ENABLE_EXTERNAL_SEGMENTATION=false
R3_SEGMENT_FRAMES=1500
R3_SEGMENT_OVERLAP_FRAMES=90
R3_KEEP_SEGMENT_OUTPUTS=false
R3_KEYFRAME_MAX_INTERVAL=30
R3_KEYFRAME_MAX_KEYFRAMES=100
R3_KEYFRAME_NOVELTY_THRESHOLD=0.985
R3_ENABLE_SEGMENT_PGO=false
