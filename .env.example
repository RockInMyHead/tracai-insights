# Runtime secrets — set these on the server or in your local .env file.
# Never commit real values.
TELEGRAM_BOT_TOKEN=
TRACKAI_DESKTOP_UPLOAD_BOT_TOKEN=
TELEGRAM_PROCESSING_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=
DEEPSEEK_API_KEY=

# R3 point-cloud export. Trajectory is returned before this background job.
R3_POINTCLOUD_MAX_POINTS=200000
R3_POINTCLOUD_STRIDE=4
R3_POINTCLOUD_MIN_CONF=1.0
R3_SAVE_FULL_DEBUG=false
# Emergency compatibility switch: true restores the old blocking export.
R3_INLINE_POINTCLOUD=false

# Long-video accuracy: overlapping 4–5 minute R3 blocks with Sim(3) stitching.
R3_SEGMENTED_LONG=true
R3_SEGMENT_MIN_DURATION_SECONDS=600
R3_LONG_TARGET_FPS=5
R3_SEGMENT_FRAMES=1500
R3_SEGMENT_OVERLAP_FRAMES=90
R3_KEEP_SEGMENT_OUTPUTS=false
R3_KEYFRAME_MAX_INTERVAL=15
R3_KEYFRAME_MAX_KEYFRAMES=160
R3_KEYFRAME_NOVELTY_THRESHOLD=0.985
R3_DISABLE_SEGMENT_PGO=false
